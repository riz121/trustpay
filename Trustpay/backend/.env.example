# Server
PORT=5000
NODE_ENV=development

# Supabase — find these in your Supabase project: Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_your_anon_key_here
SUPABASE_JWT_SECRET=sb_secret_your_service_role_key_here

# CORS - Frontend URL
FRONTEND_URL=http://localhost:5100
